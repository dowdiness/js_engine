///|
test "unicode parser filters properties and coalesces adjacent ranges" {
  let text =
    #|0041..005A ; ID_Start # Lu
    #|0061 ; ID_Start
    #|0062 ; ID_Start
    #|0030 ; ID_Continue
    #|0031..0032 ; ID_Continue
    #|00AA ; Other_Property
  let start = parse_unicode_property(text, "ID_Start")
  inspect(start.length(), content="2")
  assert_eq(start[0].0, 0x41)
  assert_eq(start[0].1, 0x5A)
  assert_eq(start[1].0, 0x61)
  assert_eq(start[1].1, 0x62)
  let part = parse_unicode_property(text, "ID_Continue")
  inspect(part.length(), content="1")
  assert_eq(part[0].0, 0x30)
  assert_eq(part[0].1, 0x32)
}

///|
test "unicode emitter preserves deterministic MoonBit table shape" {
  let tables : Map[String, Array[(Int, Int)]] = {}
  tables["ID_Start"] = [(0x41, 0x5A)]
  tables["ID_Continue"] = [(0x30, 0x39), (0x41, 0x5A)]
  let output = emit_unicode_tables("17.0.0", tables)
  assert_true(
    output.has_prefix(
      "// AUTOGENERATED by scripts/generate-unicode-id-tables.py — do not edit by hand.\n",
    ),
  )
  assert_true(
    output.contains(
      "/// 1 ranges, sorted and coalesced.\nlet id_start_ranges : Array[(Int, Int)] = [\n  (0x0041, 0x005A),\n]",
    ),
  )
  assert_true(
    output.contains(
      "/// 2 ranges, sorted and coalesced.\nlet id_continue_ranges : Array[(Int, Int)] = [\n  (0x0030, 0x0039),\n  (0x0041, 0x005A),\n]",
    ),
  )
  assert_true(output.contains("fn is_id_continue(cp : Int) -> Bool"))
  assert_true(output.has_suffix("}\n\n"))
}
